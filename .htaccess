# ────────────────────────────────────────────────────────────
# jorgesalgadomiranda.com. Apache config (Hostinger shared)
# Handles: HTTPS redirect, security headers, gzip, long cache.
# ────────────────────────────────────────────────────────────

# -------- Force HTTPS + apex → www-canonical is NOT used; we stay on apex --------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTP → HTTPS (Cloudflare handles most cases; this covers direct origin hits)
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !=https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # www → apex (Cloudflare also does this, but origin-side is a belt-and-suspenders)
  RewriteCond %{HTTP_HOST} ^www\.jorgesalgadomiranda\.com$ [NC]
  RewriteRule ^ https://jorgesalgadomiranda.com%{REQUEST_URI} [L,R=301]
</IfModule>

# -------- Security headers --------
<IfModule mod_headers.c>
  # 2 years, preload. Only enable preload after you're 100% on HTTPS permanently.
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

  # Legacy but cheap. Disallow MIME sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Don't allow framing. Prevents clickjacking.
  Header always set X-Frame-Options "SAMEORIGIN"

  # Referrer leak budget. Keep origin only
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Browsers: disable features we don't use. Expand if you add a use case.
  Header always set Permissions-Policy "accelerometer=(), autoplay=(), camera=(), cross-origin-isolated=(), display-capture=(), encrypted-media=(), fullscreen=(self), geolocation=(), gyroscope=(), keyboard-map=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(), publickey-credentials-get=(), screen-wake-lock=(), sync-xhr=(), usb=(), web-share=(), xr-spatial-tracking=()"

  # Content-Security-Policy, deliberately permissive enough for inline styles/scripts
  # that this single-file HTML relies on. Tighten after separating out scripts/styles.
  # Allowed third-parties: analytics (umami self-host + cloudflare beacon), form (web3forms),
  # booking (cal.com), external images we intentionally hotlink.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://stats.capdesis.com https://static.cloudflareinsights.com https://app.cal.com https://cal.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://assets.zyrosite.com https://capdesis.com https://*.capdesis.com https://cdn.capdesis.com https://stats.capdesis.com https://jorgesalgadomiranda.com; font-src 'self' data:; connect-src 'self' https://api.web3forms.com https://stats.capdesis.com https://cloudflareinsights.com https://app.cal.com; frame-src https://cal.com https://app.cal.com; object-src 'none'; base-uri 'self'; form-action 'self' https://api.web3forms.com; frame-ancestors 'self'; upgrade-insecure-requests"

  # Remove server banner signal
  Header unset X-Powered-By
</IfModule>

# -------- Hide sensitive files --------
<FilesMatch "^\.(git|env|htaccess|htpasswd)">
  Require all denied
</FilesMatch>
<FilesMatch "^(package\.json|bun\.lockb|package-lock\.json|README\.md|og\.html|CLAUDE\.md)$">
  Require all denied
</FilesMatch>

# -------- Gzip / Brotli (Hostinger supports both; mod_deflate is safest) --------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml application/xml text/xml
</IfModule>

# -------- Long cache for immutable assets (fonts, images) --------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresDefault "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(woff2|woff|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(png|jpg|jpeg|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=15552000"
  </FilesMatch>
</IfModule>

# -------- Nice URL handling --------
DirectoryIndex index.html

# -------- Custom 404 fallback to index (single-page style) --------
# Keep commented unless you add SPA routing. As a static multi-page site,
# a real 404 is more honest.
# ErrorDocument 404 /index.html
