# FTP credentials for manual deploy via scripts/deploy.sh
FTP_HOST=ftp.jorgesalgadomiranda.com
FTP_USER=your-ftp-username
FTP_PASS=your-ftp-password
FTP_REMOTE_DIR=/public_html

# Cal.com personal API key (for scripts that manage event types / bookings).
# Create at app.cal.com/settings/developer/api-keys. Scope is your own user.
# Never paste the real value into committed files; keep it in .env (gitignored).
CAL_API_KEY=your-cal-com-api-key
